OPENAI_API_KEY=
# Hackathon configuration. For a lower-cost local run, choose a supported
# lower-cost model in the in-app OpenAI Settings modal.
OPENAI_MODEL=gpt-5.6-sol
PORT=4387

# Optional: required only for scheduled Gmail news summaries
# Create a Desktop OAuth client in Google Cloud and add its client secret locally.
GOOGLE_CLIENT_ID=your_desktop_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_desktop_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:4390/oauth2callback

